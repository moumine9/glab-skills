{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(glab *)",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/glab-auth-guard.sh\""
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(glab *)",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/glab-auth-guard.sh\""
          }
        ]
      }
    ]
  }
}
